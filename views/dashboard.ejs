<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= pageTitle %> -LodgeEasy</title>

 <%- include('partials/headerIcon')%>
    <link rel="stylesheet" href="/output.css"/>

</head>

<body class="bg-gray-100">

<div class="flex h-screen">
 
    <!-- SIDEBAR -->
    <aside class="w-64 bg-white shadow-lg hidden md:flex flex-col">

        <div class="p-6 text-2xl font-bold text-blue-600">
            LodgeEasy
        </div>

        <nav class="flex-1 px-4 space-y-2">
          
            <a href="/dashboard" class="block px-4 py-2 rounded-lg bg-blue-100 text-blue-600 font-semibold">
                🏠 Dashboard
            </a>
        <% if( user.userType == 'Guest'){ %>
            
            <a href="/home" class="block px-4 py-2 rounded-lg hover:bg-gray-100">
                🏡 Browse Homes
            </a>
            <a
            href="/favourites"
            class="block px-4 py-2 rounded-lg hover:bg-gray-100"
          > ❤️ Favourites</a>

            <a href="/bookingList" class="block px-4 py-2 rounded-lg hover:bg-gray-100">
                📅 My Bookings
            </a>
            <% } else { %>

            <a href="/host/home-list" class="block px-4 py-2 rounded-lg hover:bg-gray-100">
                📦 My Listings
            </a>
            <a href="/host/bookings" class="block px-4 py-2 rounded-lg hover:bg-gray-100">
                📅 My Bookings
            </a>

            <a href="/host/add-home" class="block px-4 py-2 rounded-lg hover:bg-gray-100">
                ➕ Add Property
            </a>

           
             <% } %>
              <a href="/profile" class="block px-4 py-2 rounded-lg hover:bg-gray-100">
                👤 Profile
            </a>

        </nav>

        <div class="p-4 border-t">
          <form action="/logout" method="POST" class="inline">
          <button
            type="submit"
            class="px-2 py-1 bg-red-500 text-white rounded hover:bg-red-600 transition text-sm sm:text-base"
          >
            Logout
          </button>
        </form>
           
        </div>

    </aside>

   <!-- MAIN -->
<div class="flex-1 flex flex-col">

    <!-- TOP NAV -->
    <header class="bg-white shadow px-6 py-4 flex justify-between items-center">

        <h1 class="text-xl font-semibold">Dashboard</h1>

        <div class="flex items-center gap-4">
            <span class="text-gray-600">Hello, <%= user.name %></span>
            <div class="w-10 h-10 bg-blue-500 text-white flex items-center justify-center rounded-full">
                
            </div>
        </div>

    </header>

    <!-- CONTENT -->
    <main class="p-6 overflow-y-auto">

        <!-- STATS -->
        <div class="grid md:grid-cols-3 gap-6 mb-8">

            <!-- BOOKINGS -->
            <div class="bg-white p-6 rounded-2xl shadow hover:shadow-lg transition">
                <h2 class="text-gray-500">Bookings</h2>
                <p class="text-3xl font-bold text-blue-600"><%= bookings.length %></p>
            </div>

            <% if(user.userType === 'Host') { %>

                <!-- HOST: LISTINGS -->
                <div class="bg-white p-6 rounded-2xl shadow hover:shadow-lg transition">
                    <h2 class="text-gray-500">Listings</h2>
                    <p class="text-3xl font-bold text-blue-600"><%= listedHomes.length %></p>
                </div>

                <!-- HOST: EARNINGS -->
                <div class="bg-white p-6 rounded-2xl shadow hover:shadow-lg transition">
                    <h2 class="text-gray-500">Earnings</h2>
                    <p class="text-3xl font-bold text-blue-600">₹<%= earnings %></p>
                </div>

            <% } else { %>

                <!-- GUEST: TRIPS -->
                <div class="bg-white p-6 rounded-2xl shadow hover:shadow-lg transition">
                    <h2 class="text-gray-500">Trips</h2>
                    <p class="text-3xl font-bold text-blue-600"><%= bookings.length %></p>
                </div>

               

            <% } %>

        </div>

        <!-- MAIN SECTION -->
        <% if(user.userType === 'Host') { %>

            <!-- HOST: LISTINGS -->
            <div>
               
                <% if(listedHomes.length === 0) { %>
                    <p class="text-gray-500">No listings yet</p>
                <% } %>

                <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6">

                    <% listedHomes.forEach(home => { %>

                    <div class="group bg-white rounded-2xl shadow hover:shadow-xl transition overflow-hidden">

                        <div class="overflow-hidden">
                            <img src="<%= home.imageURL %>" 
                                class="h-48 w-full object-cover transform group-hover:scale-110 transition duration-500">
                        </div>

                        <div class="p-4">
                            <h3 class="font-semibold"><%= home.title %></h3>
                            <p class="text-gray-500 text-sm"><%= home.city %></p>

                            <div class="flex justify-between items-center mt-3">
                                <p class="text-blue-600 font-bold">₹<%= home.price %></p>

                                <div class="flex gap-2">
                                    <a href="/edit/<%= home._id %>" class="text-sm text-green-600 hover:underline">Edit</a>
                                    <a href="/delete/<%= home._id %>" class="text-sm text-red-500 hover:underline">Delete</a>
                                </div>
                            </div>
                        </div>

                    </div>

                    <% }) %>

                </div>
            </div>

        <% } else { %>

            <!-- GUEST: EXPLORE -->
            <div>
                <h2 class="text-2xl font-semibold mb-6">Explore Homes</h2>

                <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-6">

                    <% exploreHomes.forEach(home => { %>

                    <div class="group bg-white rounded-2xl shadow hover:shadow-xl transition overflow-hidden">

                        <div class="overflow-hidden">
                            <img src="<%= home.imageURL %>" 
                                class="h-48 w-full object-cover transform group-hover:scale-110 transition duration-500">
                        </div>

                        <div class="p-4">
                            <h3 class="font-semibold"><%= home.title %></h3>
                            <p class="text-gray-500 text-sm"><%= home.city %></p>

                            <p class="text-blue-600 font-bold mt-2">₹<%= home.price %></p>
                        </div>

                    </div>

                    <% }) %>

                </div>
            </div>

        <% } %>

        <!-- BOOKINGS (COMMON) -->
        <div class="mt-10">
            <h2 class="text-2xl font-semibold mb-6">Your Bookings</h2>

            <% if(bookings.length === 0) { %>
                <p class="text-gray-500">No bookings yet</p>
            <% } %>

            <div class="space-y-4">

                <% bookings.forEach(b => { %>
                    <div class="bg-white p-4 rounded-xl shadow flex justify-between">

                        <div>
                            <p class="font-semibold"><%= b.homeId %></p>
                            <p class="text-sm text-gray-500"><%= b.checkIn %></p>
                        </div>

                        <p class="text-blue-600 font-bold">₹<%= b.totalAmount %></p>

                    </div>
                <% }) %>

            </div>
        </div>

    </main>

</div>

</div>

</body>
</html>