<!DOCTYPE html>
<html lang="en">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <link rel="stylesheet" href="/output.css" />
  <title><%= pageTitle %> -LodgeEasy</title>
  <%- include('../partials/headerIcon')%>
</head>

<body class="bg-gray-50">
  <%- include('../partials/nav') %>
    <main class="w-[calc(100%-2rem)] max-w-4xl mx-auto bg-white shadow-lg rounded-lg p-5 sm:p-8 mt-28 sm:mt-24 mb-12">
      <h2 class="text-2xl sm:text-3xl text-red-500 font-bold text-center mb-6 break-words">
        Details of <%= home.name %>
      </h2>

      <div class="space-y-8">
        <!-- Image -->
        <div class="rounded-lg overflow-hidden">
          <img src="<%= home.imageURL %>" alt="<%= home.name %>" class="w-full h-96  object-cover">
        </div>
          <div>
        
        <p class="text-base sm:text-lg font-semibold text-gray-600 mb-2 break-words"><%= home.description %></p>
          </div>

        <!-- Details Grid -->
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6  mt-10">
          
          
          <div>
        <h3 class="text-lg font-semibold text-gray-800 mb-2">Facilities</h3>
        <p class="text-gray-600 break-words"><%= home.amenities %></p>
          </div>

          <div>
        <h3 class="text-lg font-semibold text-gray-800 mb-2">Location</h3>
        <p class="text-gray-600"><%= home.city %></p>
          </div>

          <div>
        <h3 class="text-lg font-semibold text-gray-800 mb-2">Home Type</h3>
        <p class="text-gray-600"><%= home.homeType %></p>
          </div>


          <div>
        <h3 class="text-lg font-semibold text-gray-800 mb-2">Max Guests</h3>
        <p class="text-gray-600"><%= home.maxGuests %></p>
          </div>

          
        </div>

        <div>
        <h3 class="text-lg font-semibold text-gray-800 mb-2">Price</h3>
        <p class="text-green-600 text-2xl font-bold">₹<%= home.price %></p>
          </div>

          <a href="/bookings/<%= home._id %>"
                    class="block w-full mt-auto bg-indigo-600 hover:bg-indigo-700 text-center text-white py-3 px-4 rounded-lg font-semibold transition">Book Now</a>
      </div>
    </main>
    <%- include('../partials/footer')%>
</body>

</html>
