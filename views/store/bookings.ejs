<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %> -LodgeEasy</title>
  <%- include('../partials/headerIcon')%>
  <link rel="stylesheet" href="/output.css" />
</head>
<body class="bg-gray-50 text-gray-800 min-h-screen">
  <%- include('../partials/nav')%>

  <main id="taskbar" class="max-w-6xl mx-auto px-4 sm:px-6 py-10 pt-28 sm:pt-24">
    <% if(isLoggedIn){ %>
      <section class="mb-6">
        <h1 class="text-2xl font-bold text-gray-800">Book your home</h1>
        <div class="mt-3 bg-white rounded-xl shadow p-4 text-sm sm:text-base">
          <p class="font-semibold text-gray-800 mb-2">Property owner details</p>
          <ul class="space-y-1 text-gray-600">
            <li><span class="font-medium text-gray-700">Name:</span> <%= users.firstName %> <%= users.lastName %></li>
            <li><span class="font-medium text-gray-700">Email:</span> <%= users.email %></li>
          </ul>
        </div>
      </section>
    <% } %>

    <section class="max-w-5xl mx-auto bg-white rounded-2xl shadow-lg overflow-hidden">
      <div class="grid grid-cols-1 md:grid-cols-2">
        <div class="h-72 md:h-auto">
          <img src="<%= home.imageURL %>" alt="<%= home.name %>" class="w-full h-full object-cover">
        </div>

        <div class="p-5 sm:p-8 flex flex-col justify-between">
          <div>
            <h2 class="text-2xl sm:text-3xl font-bold mb-2 text-gray-900"><%= home.title || home.name %></h2>
            <p class="text-gray-600 mb-4"><%= home.city %></p>
            <p class="text-xl font-semibold mb-6">&#8377;<span id="pricePerNight"><%= home.price %></span> / night</p>
          </div>

          <form action="/booking/create/<%= home._id %>" method="POST" class="space-y-4 border-t border-gray-200 pt-6">
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div>
                <label for="checkIn" class="block text-sm font-medium mb-1">Check-in Date</label>
                <input type="date" id="checkIn" name="checkIn" required class="w-full border rounded-lg p-2 focus:ring-2 focus:ring-blue-500">
              </div>
              <div>
                <label for="checkOut" class="block text-sm font-medium mb-1">Check-out Date</label>
                <input type="date" id="checkOut" name="checkOut" required class="w-full border rounded-lg p-2 focus:ring-2 focus:ring-blue-500">
              </div>
            </div>

            <div>
              <label for="numGuests" class="block text-sm font-medium mb-1">Number of Guests</label>
              <input type="number" id="numGuests" name="numGuests" min="1" max="<%= home.maxGuests %>" required
                class="w-full border rounded-lg p-2 focus:ring-2 focus:ring-blue-500">
            </div>

            <div class="mt-4 bg-gray-100 rounded-lg p-4 flex flex-col sm:flex-row sm:justify-between sm:items-center gap-2">
              <span class="text-lg font-medium">Total Price:</span>
              <span class="text-2xl font-bold text-green-600">&#8377;<span id="totalPrice">0</span></span>
            </div>

            <button type="submit" class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 rounded-lg mt-4 transition">
              Confirm Booking
            </button>
          </form>
        </div>
      </div>
    </section>
  </main>

  <script>
    // 1. Define all necessary elements, including the form
    const checkIn = document.getElementById('checkIn');
    const checkOut = document.getElementById('checkOut');
    const numGuests = document.getElementById('numGuests');
    const totalPriceEl = document.getElementById('totalPrice');
    const pricePerNight = parseFloat(document.getElementById('pricePerNight').innerText);
    // Select the booking form for final validation.
    const bookingForm = document.querySelector('form[action^="/booking/create/"]'); 

    function calculateTotal() {
        const inDate = new Date(checkIn.value);
        const outDate = new Date(checkOut.value);
        const guests = parseInt(numGuests.value) || 1;

        if (checkIn.value && checkOut.value && !isNaN(inDate) && !isNaN(outDate) && outDate > inDate) {
            const nights = (outDate - inDate) / (1000 * 60 * 60 * 24);
            const total = guests * nights * pricePerNight;
            totalPriceEl.innerText = total.toFixed(2);
        } else {
            // Set to 0 if dates are invalid or incomplete
            totalPriceEl.innerText = 0; 
        }
    }

    // 2. Form Submission Interception (Final Check before sending to backend)
    if (bookingForm) {
        bookingForm.addEventListener('submit', function(event) {
            const inDate = new Date(checkIn.value);
            const outDate = new Date(checkOut.value);
            
            // Check 1: Ensure both dates have values
            if (!checkIn.value || !checkOut.value) {
                event.preventDefault(); 
                alert('Booking Error: Please select both Check-in and Check-out Dates.');
                return;
            }

            // Check 2: Check-out must be strictly after Check-in
            if (outDate <= inDate) {
                event.preventDefault(); // STOP the form submission

                alert('Booking Error: The Check-out Date must be strictly after the Check-in Date.');
                checkOut.focus();
            }
        });
    }

    // 3. Attach listeners for changes
    checkIn.addEventListener('change', calculateTotal);
    checkOut.addEventListener('change', calculateTotal);
    numGuests.addEventListener('input', calculateTotal); 

    // Optional UX improvement: Prevent users from picking past dates
    const today = new Date().toISOString().split('T')[0];
    checkIn.min = today;
    checkIn.addEventListener('change', () => {
        // Automatically set minimum check-out date to check-in date
        checkOut.min = checkIn.value;
        calculateTotal();
    });

    // Initial calculation on page load
    calculateTotal(); 
  </script>
</body>
</html>
