

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title><%= pageTitle %> </title>

 <%- include('partials/headerIcon')%>
  <link rel="stylesheet" href="/output.css"/>
</head>



<body class="bg-gray-50">

    <%- include('partials/nav')%>

     <!-- HERO SECTION -->
   <section class="relative h-[60vh] flex items-center justify-center overflow-hidden">

    <!-- Background Image -->
    <img src="../uploads/hero.png" 
         class="absolute inset-0 w-full h-full object-cover" 
         alt="LodgeEasy">

    <!-- Overlay -->
    <div class="absolute inset-0 bg-black/30"></div>

    <!-- Content -->
    <div class="relative z-10 bg-white/90 backdrop-blur-md p-8 rounded-2xl shadow-xl text-center w-[90%] max-w-2xl transition-all duration-500 hover:scale-[1.02]">

        <h1 class="text-4xl font-bold mb-3 text-gray-800">
            Find Your Perfect Stay
        </h1>

        <p class="text-gray-600 mb-6">
            Book rooms, hostels, and homes easily
        </p>

        <!-- Search -->
        <form action="/search-results" method="GET" 
              class="flex items-center bg-white rounded-xl overflow-hidden shadow-md">

            <input type="text" name="city" placeholder="Search location"
                class="flex-1 px-4 py-3 outline-none text-gray-700">

            <button 
                class="bg-blue-600 hover:bg-blue-700 transition px-6 py-3 text-white font-semibold">
                Search
            </button>
        </form>

    </div>
</section>
<div class="grid md:grid-cols-3 gap-8 max-w-6xl mx-auto">

    <div class="bg-white p-8 rounded-2xl shadow hover:shadow-xl transition text-center hover:-translate-y-2">
        <div class="text-3xl mb-3">💰</div>
        <h3 class="font-semibold text-lg mb-2">Affordable</h3>
        <p class="text-gray-500">Best prices for every budget</p>
    </div>

    <div class="bg-white p-8 rounded-2xl shadow hover:shadow-xl transition text-center hover:-translate-y-2">
        <div class="text-3xl mb-3">✅</div>
        <h3 class="font-semibold text-lg mb-2">Trusted</h3>
        <p class="text-gray-500">Verified hosts and listings</p>
    </div>

    <div class="bg-white p-8 rounded-2xl shadow hover:shadow-xl transition text-center hover:-translate-y-2">
        <div class="text-3xl mb-3">⚡</div>
        <h3 class="font-semibold text-lg mb-2">Easy Booking</h3>
        <p class="text-gray-500">Simple and fast process</p>
    </div>

</div>
<section class="py-16 px-6 max-w-7xl mx-auto">
    <h2 class="text-3xl font-bold text-center mb-12">Featured Homes</h2>

    <div class="grid sm:grid-cols-2 md:grid-cols-3 gap-8">
        <% registeredHomes.slice(0,6).forEach(home => { %>

        <div class="group bg-white rounded-2xl shadow hover:shadow-2xl transition overflow-hidden">

            <!-- Image -->
            <div class="overflow-hidden">
                <img src="<%= home.imageURL %>" 
                    class="h-52 w-full object-cover transform group-hover:scale-110 transition duration-500">
            </div>

            <!-- Content -->
            <div class="p-5">
                <h3 class="font-bold text-lg"><%= home.title %></h3>
                <p class="text-gray-500 text-sm"><%= home.city %></p>

                <div class="flex justify-between items-center mt-4">
                    <p class="text-blue-600 font-bold">₹<%= home.price %>/night</p>
                   <a href="/homes/<%= home._id %>" 
                    class="text-sm text-blue-600 hover:underline">
                    View Details
                    </a>
                </div>
            </div>

        </div>

        <% }) %>
    </div>
    <div class="text-center mt-10">
    <a href="/home" 
       class="inline-block bg-blue-600 text-white px-6 py-3 rounded-lg font-semibold shadow hover:bg-blue-700 transition">
        Browse More Homes
    </a>
</div>
</section>
<section class="bg-gradient-to-r from-blue-600 to-indigo-600 text-white text-center py-16">

    <h2 class="text-3xl font-bold mb-4">Become a Host</h2>
    <p class="mb-8 text-lg">Earn money by listing your property</p>

    <a href="/signup" 
       class="bg-white text-blue-600 px-8 py-3 rounded-full font-semibold shadow hover:shadow-lg transition">
        Get Started
    </a>

</section>
  
<%- include('partials/footer')%>
</body>
</html>