<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
   <link rel="stylesheet" href="/output.css"/>
  <title><%= pageTitle %> -LodgeEasy</title>
  <%- include('../partials/headerIcon')%>
</head>

  <body class="bg-gray-50 min-h-screen">
    <%- include('../partials/nav') %>
    <main class="w-[calc(100%-2rem)] max-w-md mx-auto mt-28 sm:mt-24 mb-8 p-6 sm:p-8 bg-white rounded-lg shadow-md">
      <h1 class="text-2xl sm:text-3xl font-bold mb-6 text-center text-gray-800"><%= editing ? "Edit" : "Register" %> Your Home</h1>
      <form action="/host/<%= editing ? "edit-home" : "add-home" %>" method="POST" enctype="multipart/form-data" class="space-y-4">
        <input type="hidden" name="id" value="<%= editing ? home.id : '' %>" />
        <input type="text"
          name="name"
          value="<%= editing ? home.name : '' %>"
          placeholder="Enter your House Name"
          class="input-field"/>
        <input
          type="number"
          name="price"
          value="<%= editing ? home.price : '' %>"
          placeholder="Price Per Night"
          class="input-field"/>
        <input
          type="text"
          name="city"
          value="<%= editing ? home.city : '' %>"
          placeholder="Location"
          class="input-field"/>
          <div>
          <input type="number" name="maxGuests" value="<%= editing ? home.maxGuests : '' %>"
          placeholder="Max guests allowed" required
          class="input-field" />
        </div>
        <input type="text"
          name="description"
          value="<%= editing ? home.description : '' %>"
          placeholder="Describe your home"
          class="input-field">
       
      <select name="homeType" value="<%= editing ? home.homeType : '' %>"
        required
      class="input-field">
      <option value="">Select Home Type</option>
      <option value="Room">Room</option>
      <option value="Apartment">Apartment</option>
      <option value="Flat">Flat</option>
      <option value="Villa">Villa</option>
      <option value="Hostel">Hostel</option>
    </select>

    <div>
      <label class="block text-blue-600 mb-2 font-medium">Amenities</label>
      <div class="flex flex-wrap gap-3">
        <label class="flex items-center gap-2 cursor-pointer"><input type="checkbox" name="amenities" value="ac" class="w-4 h-4"> <span class="text-sm">AC</span></label>
        <label class="flex items-center gap-2 cursor-pointer"><input type="checkbox" name="amenities" value="wifi" class="w-4 h-4"> <span class="text-sm">WiFi</span></label>
        <label class="flex items-center gap-2 cursor-pointer"><input type="checkbox" name="amenities" value="pool" class="w-4 h-4"> <span class="text-sm">Pool</span></label>
        <label class="flex items-center gap-2 cursor-pointer"><input type="checkbox" name="amenities" value="parking" class="w-4 h-4"> <span class="text-sm">Parking</span></label>
        <label class="flex items-center gap-2 cursor-pointer"><input type="checkbox" name="amenities" value="kitchen" class="w-4 h-4"> <span class="text-sm">Kitchen</span></label>
      </div>
    </div>
  
    <div>
      <label class="block text-blue-600 mb-2 font-medium">Upload Image</label>
      <input
          type="file"
          name="imageURL"
          accept="image/*"
          class="w-full text-blue-700 file:mr-4 file:py-2 file:px-4 file:rounded file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100">
    </div>

    <input type="submit" value="<%= editing ? 'Update Home' : 'Add Home' %>" class="primary-btn" />
        
      </form>
    </main>
  </body>
</html>
