<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= pageTitle %> -LodgeEasy</title>
  <%- include('../partials/headerIcon')%>

  <!-- <link rel="stylesheet" href="home.css" /> -->
  <link rel="stylesheet" href="/output.css" />
</head>

<body class="bg-gray-50 min-h-screen font-sans">
  <header>
    <%- include('../partials/nav')%>
    <% if(isLoggedIn){ %>
    <div class="w-[calc(100%-2rem)] max-w-md mx-auto mt-28 sm:mt-24 bg-white rounded-xl shadow-lg p-6 sm:p-8">
      <h1 class="text-2xl font-bold text-blue-700 mb-6 text-center">Register Your Home</h1>
      
      <form action="/host/add-home" method="POST" enctype="multipart/form-data" class="space-y-5">
        <div>
          <input type="text" name="name" placeholder="Enter your home name"  required
            class="input-field" />
        </div>
        <div>
          <input type="text" name="city" placeholder="Enter City of your home" required
            class="input-field" />
        </div>
        <div>
          <input type="number" name="price" placeholder="Enter Price per night" required
            class="input-field" />
        </div>
        <div>
          <input type="number" name="maxGuests" placeholder="Max guests allowed"  required
          class="input-field" />
        </div>
        <div>
          <input type="text" name="description" placeholder="description"
            class="input-field" />
        </div>

          <!-- Max Guests -->
  

  <!-- Type -->
  <div>
    <select name="homeType"  required
      class="w-full px-4 py-2 border border-blue-200 rounded bg-white focus:outline-none focus:ring-2 focus:ring-blue-400 transition">
      <option value="">Select Home Type</option>
      <option value="Bunglow">Banglow</option>
      <option value="Apartment">Apartment</option>
      <option value="Guest House">Guest House</option>
      <option value="Villa">Villa</option>
      <option value="Hostel">Hostel</option>
    </select>
  </div>

        <!-- Amenities -->
    <div>
      <label class="block text-blue-600 mb-1 font-medium">Amenities</label>
      <div class="flex flex-wrap gap-2">
        <label class="flex items-center gap-1"><input type="checkbox" name="amenities" value="ac"> AC</label>
        <label class="flex items-center gap-1"><input type="checkbox" name="amenities" value="wifi"> WiFi</label>
        <label class="flex items-center gap-1"><input type="checkbox" name="amenities" value="pool"> Pool</label>
        <label class="flex items-center gap-1"><input type="checkbox" name="amenities" value="parking"> Parking</label>
        <label class="flex items-center gap-1"><input type="checkbox" name="amenities" value="parking"> Kitchen</label>
      </div>
    </div>
        <div>
          <label class="block text-blue-600 mb-1 font-medium">Upload Image</label>
          <input type="file" name="imageURL" accept="image/*"  required
            class="w-full text-blue-700 file:mr-4 file:py-2 file:px-4 file:rounded file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" />
        </div>
        <div>
          <input type="submit" value="Register Home"
           class="primary-btn"  />
        </div>
      </form>
    </div>
    <% } %>
  </header>
</body>
</html>
